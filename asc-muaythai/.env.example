# Copier ce fichier en .env.local pour dev local
# Sur Vercel : ajouter ces variables dans Settings > Environment Variables

BREVO_API_KEY=xkeysib-VOTRE_CLE_ICI

# Secret utilisé pour signer les sessions admin ET pour dériver les noms de
# blobs sensibles (mot de passe, token de reset) afin qu'ils restent
# impossibles à deviner. Générer une valeur aléatoire, ex : openssl rand -hex 32
ADMIN_SESSION_SECRET=

# Mot de passe initial de l'espace admin (utilisé uniquement avant le premier
# changement de mot de passe, qui passe ensuite par Vercel Blob)
ADMIN_PASSWORD=

# Jeton secret pour le webhook HelloAsso (génère une valeur aléatoire, ex :
# openssl rand -hex 24, puis ajoute-le à la fin de l'URL de callback configurée
# dans HelloAsso > Mon Compte > Intégrations et API > Notifications :
# https://www.asc-muaythai.fr/api/webhook-helloasso?key=VALEUR_ICI
HELLOASSO_WEBHOOK_TOKEN=
